# ================================================
# CTRL-LICITAÇÃO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ================================================

# Banco de Dados (PostgreSQL — Supabase recomendado)
# Exemplo: postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://..."

# NextAuth — Segredo para JWT (gere em: https://generate-secret.vercel.app/32)
NEXTAUTH_SECRET="cole-uma-string-aleatoria-longa-aqui"

# URL do sistema (localhost para dev, URL do Vercel para produção)
NEXTAUTH_URL="http://localhost:3000"

# ================================================
# OPCIONAL — Integração com IA (Anthropic Claude)
# Obtenha sua chave em: https://console.anthropic.com
# Sem essa chave, o botão "Analisar com IA" fica desabilitado
# Com ela, funciona automaticamente — custo ~$0.001 por análise
# ================================================
# ANTHROPIC_API_KEY="sk-ant-..."
